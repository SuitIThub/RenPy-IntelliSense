{
  "name": "renpy-intellisense-monorepo",
  "version": "1.2.0",
  "description": "Ren'Py Language Server - monorepo",
  "private": true,
  "scripts": {
    "compile": "pnpm -r compile",
    "watch": "pnpm -r --parallel watch",
    "generate-index": "node scripts/generate-index.mjs",
    "install-all": "pnpm install",
    "package": "powershell -ExecutionPolicy Bypass -File scripts/build-vsix.ps1"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
